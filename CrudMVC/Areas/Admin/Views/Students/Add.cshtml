@model CrudMVC.Models.AddStudentViewModel

<main class="app-main">
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6"><h3 class="mb-0">Add Student</h3></div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-end">
                        <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="breadcrumb-item active">Add Student</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="app-content">
        <div class="container-fluid">
            <div class="col-md-6 p-0">
                <div class="card card-primary card-outline mb-2">
                    <div class="card-header py-1">
                        <div class="card-title">Student Info</div>
                    </div>

                    <form asp-action="Add" method="post">
                        @Html.AntiForgeryToken()
                        <div class="card-body py-2 px-3">
                            <div class="mb-2">
                                <label asp-for="Name" class="form-label small"></label>
                                <input asp-for="Name" class="form-control form-control-sm" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="Email" class="form-label small"></label>
                                <input asp-for="Email" class="form-control form-control-sm" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="Phone" class="form-label small"></label>
                                <input asp-for="Phone" class="form-control form-control-sm" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="RollNumber" class="form-label small"></label>
                                <input asp-for="RollNumber" class="form-control form-control-sm" />
                                <span asp-validation-for="RollNumber" class="text-danger small"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="ClassId" class="form-label small"></label>
                                <select asp-for="ClassId" class="form-select form-select-sm" asp-items="Model.Classes">
                                    <option value="">-- Select Class --</option>
                                </select>
                                <span asp-validation-for="ClassId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="card-footer py-2 px-3">
                            <a asp-action="List" class="btn btn-secondary btn-sm">Back</a>
                            <button type="submit" class="btn btn-primary btn-sm">Add Student</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}