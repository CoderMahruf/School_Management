@model IEnumerable<CrudMVC.Models.Entities.Class>

<main class="app-main">

    <!-- Page Header -->
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6">
                    <h3 class="mb-0">Class List</h3>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-end">
                        <li class="breadcrumb-item">
                            <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="breadcrumb-item active">Classes</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <!-- Page Content -->
    <div class="app-content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <!-- Card Wrapper -->
                    <div class="card card-info card-outline mb-4">
                        <div class="card-header py-2 d-flex align-items-center">
                            <a asp-action="Add" class="btn btn-primary btn-sm ms-auto">➕ Add Class</a>
                        </div>

                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped table-sm mb-0">
                                    <thead>
                                        <tr class="text-center">
                                            <th>Class Name</th>
                                            <th>Subjects</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cls in Model)
                                        {
                                            <tr>
                                                <!-- Class Name Column -->
                                                <td>
                                                    <input type="text"
                                                           name="name"
                                                           form="form-@cls.Id"
                                                           value="@cls.Name"
                                                           class="form-control form-control-sm" />
                                                </td>

                                                <!-- Subjects Column -->
                                                <td>
                                                    <form id="form-@cls.Id" asp-action="UpdateClass" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@cls.Id" />

                                                        @foreach (var subject in ViewBag.Subjects)
                                                        {
                                                            bool isChecked = cls.ClassSubjects.Any(cs => cs.SubjectId == subject.Id);

                                                            <div class="form-check form-check-inline">
                                                                <input class="form-check-input"
                                                                       type="checkbox"
                                                                       name="selectedSubjectIds"
                                                                       value="@subject.Id"
                                                                       @(isChecked ? "checked" : "") />
                                                                <label class="form-check-label">@subject.Name</label>
                                                            </div>
                                                        }
                                                    </form>
                                                </td>

                                                <!-- Actions Column -->
                                                <td class="text-end">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <!-- Save Button -->
                                                        <button type="submit" form="form-@cls.Id" class="btn btn-success btn-sm">Save</button>

                                                        <!-- Delete Button -->
                                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this class?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@cls.Id" />
                                                            <button class="btn btn-danger btn-sm">Delete</button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!-- End Card -->
                </div>
            </div>
        </div>
    </div>
</main>