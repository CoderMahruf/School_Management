@model RegisterVM

@{
    ViewData["Title"] = "Register";
}

<div class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-lg border-0 rounded-4" style="width: 100%; max-width: 480px;">

        <!-- Header -->
        <div class="card-header bg-white text-center border-0 pt-4 pb-0">
            <h3 class="fw-bold mb-2">Create an Account </h3>
            <p class="text-muted mb-0">Sign up to get started</p>
        </div>

        <!-- Body -->
        <div class="card-body p-5">

            <form asp-action="Register" asp-controller="Account" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Role Selection  -->
                <div class="form-floating mb-3">
                    <select asp-for="Role" class="form-select rounded-3">
                        <option value=""> Select Role </option>
                        <option value="Admin">Admin</option>
                        <option value="Teacher">Teacher</option>
                        <option value="Student">Student</option>
                    </select>
                    <label asp-for="Role"></label>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>


                <!-- First -->
                <div class="form-floating mb-3">
                    <input asp-for="FirstName" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="FirstName">First Name</label>
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <!-- Last -->
                <div class="form-floating mb-3">
                    <input asp-for="LastName" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="LastName">Last Name</label>
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <!-- Image -->
                <div class="form-floating mb-3">
                    <input asp-for="ImageFile" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="ImageFile">Profile Image</label>
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                </div>
                <!-- Email -->
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="Email">Email address</label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <!-- Phone -->
                <div class="form-floating mb-3">
                    <input asp-for="PhoneNumber" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="PhoneNumber">Phone Number</label>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <!-- Password -->
                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="Password" />
                    <label asp-for="Password">Password</label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-floating mb-4">
                    <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Confirm Password" />
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary w-100 rounded-3 py-2 fw-semibold">
                    Register
                </button>

                <!-- Already have account -->
                <div class="text-center mt-4">
                    <small class="text-muted">
                        Already have an account?
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-semibold">
                            Login
                        </a>
                    </small>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
