@model ForgetPasswordVM

@{
    ViewData["Title"] = "ResetPassword";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-lg border-0 rounded-4" style="width:100%; max-width:450px;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <h3 class="fw-bold">Reset Your Password 🔐</h3>
                <p class="text-muted">Enter your new password below</p>
            </div>

            <form asp-action="ResetPassword" asp-controller="Account" method="post">

                <!-- Hidden fields -->
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Token" />

                <div class="form-floating mb-3">
                    <input asp-for="Password" class="form-control rounded-3" placeholder="New Password" />
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="ConfirmPassword" class="form-control rounded-3" placeholder="Confirm Password" />
                    <label asp-for="ConfirmPassword"></label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100 rounded-3 py-2 fw-semibold">
                    Reset Password
                </button>

                <div class="text-center mt-4">
                    <a asp-action="Login"
                       asp-controller="Account"
                       class="small text-decoration-none">
                        Back to Login
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
